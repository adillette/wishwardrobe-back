	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 현재 날짜 설정 (YYYYMMDD)",
					"const now = new Date();",
					"const year = now.getFullYear();",
					"const month = String(now.getMonth() + 1).padStart(2, '0');",
					"const day = String(now.getDate()).padStart(2, '0');",
					"pm.variables.set('currentDate', `${year}${month}${day}`);",
					"",
					"// 현재 시각 설정 (HHMM) - 정시 기준으로 내림",
					"const hour = String(now.getHours()).padStart(2, '0');",
					"pm.variables.set('currentTime', `${hour}00`);",
					"",
					"console.log('현재 날짜:', pm.variables.get('currentDate'));",
					"console.log('현재 시각:', pm.variables.get('currentTime'));"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 응답 시간 체크",
					"pm.test('응답 시간이 5초 이내', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});",
					"",
					"// 상태 코드 체크",
					"pm.test('상태 코드가 200', function () {",
					"    pm.response.to.have.status(200);",
					"});",
					"",
					"// JSON 응답 체크",
					"if (pm.response.headers.get('Content-Type').includes('application/json')) {",
					"    pm.test('JSON 응답 파싱 성공', function () {",
					"        pm.response.to.be.json;",
					"    });",
					"}"
				]
			}
		}
