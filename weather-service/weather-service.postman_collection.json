{
  "info": {
    "name": "Weather Service API",
    "description": "기상청 API 연동 테스트 - 지역명 기반 날씨 조회",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082",
      "type": "string"
    },
    {
      "key": "location",
      "value": "청운동",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "날씨 조회 - 청운동",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/weather?location={{location}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "weather"],
          "query": [
            {
              "key": "location",
              "value": "{{location}}",
              "description": "동 단위 지역명 (location_data.json의 3단계 값)"
            }
          ]
        },
        "description": "지역명으로 날씨 정보 조회 (기상청 API 연동)"
      },
      "response": []
    },
    {
