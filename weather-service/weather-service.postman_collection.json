    {
      "name": "날씨 조회 - 위경도 (서울 시청)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/weather/coordinates?lat=37.5665&lon=126.9780",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "weather", "coordinates"],
          "query": [
            {
              "key": "lat",
              "value": "37.5665",
